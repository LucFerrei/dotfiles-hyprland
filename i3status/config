# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
        colors = false
        interval = 5
}

# order += "ipv6"
order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
# order += "disk /"
# order += "load"
order += "memory"
order += "tztime local"

wireless _first_ {
        format_up = "W: (%quality at %essid)"
        format_down = "W: down"
}

ethernet _first_ {
        format_up = "E: (%speed)"
        format_down = "E: down"
}

battery all {
        format = "%status %percentage %remaining"
}

disk "/" {
        format = "%avail"
}

load {
        format = "%1min"
}

memory {
    # Shows: 4.2 GiB / 16.0 GiB
    format = "󰍛 %used / %total"
    
    # Alert when less than 10% is left
    threshold_degraded = "10%"
    format_degraded = "󰀦 LOW MEM: %available"
    
    # Use binary prefixes (GiB) instead of decimal (GB)
    memory_used_method = "memavailable"
}

tztime local {
    # Result: 2026-01-25 Sun 21:40
    format = "%Y-%m-%d %a %H:%M"
}
